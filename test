        window.addToCart = (id,name,price,img,stockMax) => {
            price = parseFloat(price); 
            const ex = cart.find(i=>i.id===id);
            if(ex) {
                if(ex.quantity >= stockMax) { alert("Maximum stock limit reached for this item."); return; }
                ex.quantity++;
            } else {
                if(stockMax <= 0) return;
                cart.push({id,name,price,img,quantity:1, stockMax: stockMax});
            }
            updateCartUI();
        };

        function updateCartUI() {
            document.getElementById('cart-count').textContent = cart.reduce((a,b)=>a+b.quantity,0);
            const c = document.getElementById('cartItemsContainer');
            
            if(cart.length===0) { 
                c.innerHTML='<p style="text-align:center; padding: 25px 0; color: #777;">Your cart is empty.</p>'; 
                document.getElementById('cart-summary').style.display='none'; 
                checkOrderValidity(); 
                return; 
            }
            
            document.getElementById('cart-summary').style.display='block';
            document.getElementById('delivery-fee-display').textContent = `₹${globalDeliveryCharge.toFixed(2)}`;

            c.innerHTML='';
            let sub=0;
            
            cart.forEach(i => {
                sub += i.price * i.quantity;
                const itemDiv = document.createElement('div');
                itemDiv.className = 'cart-item';
                itemDiv.innerHTML = `
                    <img src="${i.img}" alt="${i.name}">
                    <div style="flex: 1;">
                        <h4 style="margin:0 0 5px 0; font-size:1em;">${i.name}</h4>
                        <p style="margin:0; color:var(--primary-color); font-weight:700;">₹${i.price.toFixed(2)}</p>
                    </div>
                    <div class="qty-controls">
                        <button onclick="modQty('${i.id}', -1)">-</button>
                        <span>${i.quantity}</span>
                        <button onclick="modQty('${i.id}', 1)">+</button>
                    </div>
                `;
                c.appendChild(itemDiv);
            });
            
            document.getElementById('subtotal-price').textContent = `₹${sub.toFixed(2)}`;
            document.getElementById('total-price').textContent = `₹${(sub+globalDeliveryCharge).toFixed(2)}`;
            checkOrderValidity(); 
        }

        window.modQty = (id,n) => {
            const i = cart.find(x=>x.id===id);
            if(i) { 
                if(n > 0 && i.quantity >= i.stockMax) { alert("Maximum stock limit reached."); return; }
                i.quantity+=n; 
                if(i.quantity<=0) cart=cart.filter(x=>x.id!==id); 
                updateCartUI(); 
            }
        };

        function pushNotification(title, body) {
            if(!currentUser) return;
            db.ref(`notifications/${currentUser.uid}`).push({
                title: title, body: body, timestamp: Date.now(), read: false
            });
        }
        
        function listenForStatusUpdates() {
            if(!currentUser) return;
            const notificationOrdersRef = db.ref('orders').orderByChild('userId').equalTo(currentUser.uid);
            notificationOrdersRef.on('child_changed', (snapshot) => {
                const order = snapshot.val();
                const orderId = snapshot.key;
                
                const lastNotified = order.lastNotifiedStatus || 'Placed';
                if (lastNotified !== order.status && order.status) {
                    pushNotification(`Order #${orderId.substring(1,6)} Update`, `Your order is now: ${order.status}`);
                    db.ref(`orders/${orderId}/lastNotifiedStatus`).set(order.status);
                }
            });
        }
        
        function listenForUnreadNotifications() {
            if(!currentUser) return;
            db.ref(`notifications/${currentUser.uid}`).on('value', snap => {
                let unreadCount = 0;
                if(snap.exists()) {
                    snap.forEach(c => {
                        if(!c.val().read) unreadCount++;
                    });
                }
                const badge = document.getElementById('notif-badge');
                if(unreadCount > 0) {
                    badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            });
        }

        function markNotificationsAsRead() {
            if(!currentUser) return;
            db.ref(`notifications/${currentUser.uid}`).once('value', snap => {
                if(snap.exists()) {
                    const updates = {};
                    snap.forEach(child => {
                        if(!child.val().read) updates[`${child.key}/read`] = true;
                    });
                    if(Object.keys(updates).length > 0) {
                        db.ref(`notifications/${currentUser.uid}`).update(updates);
                    }
                }
            });
        }

        window.deleteNotification = (key) => {
            if (!currentUser || !key) return;
            db.ref(`notifications/${currentUser.uid}/${key}`).remove();
        };

        function loadNotifications() {
            if(!currentUser) return;
            if (notificationsListener) notificationsListener.off();
            const container = document.getElementById('notificationListContainer');
            container.innerHTML = '<p style="text-align:center; padding:20px;">Loading alerts...</p>';
            
            notificationsListener = db.ref(`notifications/${currentUser.uid}`).orderByChild('timestamp');
            notificationsListener.on('value', snap => {
                if(!snap.exists()) {
                    container.innerHTML = '<div style="text-align:center; margin-top:40px; color:#999;"><i class="fas fa-bell-slash" style="font-size:2.5em; margin-bottom:12px;"></i><p>No notifications yet</p></div>';
                    return;
                }
                const alerts =[];
                snap.forEach(c => alerts.push({key: c.key, ...c.val()}));
                alerts.reverse(); 
                
                let html = '';
                alerts.forEach(n => {
                    try {
                        const date = n.timestamp ? new Date(n.timestamp).toLocaleString() : 'Date unavailable';
                        let titleText = n.title || 'Alert';
                        let bodyText = n.body || '';
                        let icon = 'fa-info-circle';
                        if(titleText.includes('Placed')) icon = 'fa-check-circle';
                        if(titleText.includes('Update')) icon = 'fa-shipping-fast';
                        
                        html += `
                            <div class="notification-card" style="${n.read ? 'opacity:0.7;' : 'border-left: 4px solid var(--primary-color);'}">
                                <button class="delete-notif-btn" onclick="deleteNotification('${n.key}')" title="Delete notification">
                                    <i class="fas fa-times"></i>
                                </button>
                                <div class="notif-icon-box"><i class="fas ${icon}"></i></div>
                                <div class="notif-content" style="flex:1;">
                                    <h4 style="margin:0 0 4px 0; color:#2d3436; font-size:1em;">${titleText}</h4>
                                    <p style="margin:0; font-size:0.85em; color:#636e72;">${bodyText}</p>
                                    <span class="notif-time" style="font-size:0.75em; color:#b2bec3;">${date}</span>
                                </div>
                            </div>`;
                    } catch(e) { console.error("Skipped a corrupted notification:", e); }
                });
                container.innerHTML = html;
                if(document.getElementById('notificationsPage').classList.contains('active')) {
                    markNotificationsAsRead();
                }
            });
        }
        
        function deductStock() {
            cart.forEach(item => {
                db.ref('dishes/' + item.id + '/stock').once('value', s => {
                    let cStock = s.val();
                    if(cStock && cStock >= item.quantity) {
                        db.ref('dishes/' + item.id).update({stock: cStock - item.quantity});
                    }
                });
            });
        }

        function saveOrderToFirebase(paymentMethod, paymentId = null) {
            const totalAmount = (cart.reduce((a, b) => a + b.price * b.quantity, 0) + globalDeliveryCharge);
            const dCode = Math.floor(100000 + Math.random() * 900000);
            
            const uName = nameInput.value.trim() || currentUserData.name || currentUser.displayName || 'Unknown';

            const order = {
                userId: currentUser.uid, userName: uName, email: currentUser.email,
                phone: phoneInput.value.trim(), address: addressInput.value.trim(),
                village: villageInput.value.trim(), pin: pinInput.value.trim(),
                district: districtInput.value.trim(), state: stateInput.value.trim(),
                location: { lat: document.getElementById('lat').value, lng: document.getElementById('lng').value },
                items: cart, total: totalAmount.toFixed(2), status: 'Placed', lastNotifiedStatus: 'Placed',
                method: paymentMethod, paymentId: paymentId, paymentStatus: paymentId ? 'Paid' : 'Pending', deliveryCode: dCode, timestamp: new Date().toISOString(),
                driverId: null
            };
            db.ref('orders').push(order).then((snap) => {
                deductStock();
                pushNotification("Order Placed", `Order #${snap.key.substring(1,6)} has been placed successfully.`);
                cart =[]; updateCartUI();
                const codeElement = document.getElementById('thankYouDeliveryCode');
                if (codeElement) { codeElement.textContent = dCode; }
                showPage('thankYouPage');
            }).catch(err => {
                alert('Failed to save order. Please try again or contact support.');
                console.error("Firebase write error: ", err);
            });
        }
        
