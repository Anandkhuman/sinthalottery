                item.addEventListener('click', () => {
                    navItems.forEach(nav => nav.classList.remove('active'));
                    item.classList.add('active');
                    const targetId = item.dataset.driverTarget;
                    sections.forEach(sec => sec.classList.remove('active'));
                    if(targetId) {
                        document.getElementById(targetId).classList.add('active');
                        document.getElementById('driverPage').scrollTo(0,0);
                    }
                });
            });

            document.getElementById('saveDriverProfileBtn').onclick = () => {
                const pName = document.getElementById('driverProfileName').value.trim();
                const pPhone = document.getElementById('driverProfilePhone').value.trim();
                if(!pName || !pPhone) { alert("Please fill both name and phone."); return; }
                db.ref('users/' + currentUser.uid).update({
                    name: pName, driverPhone: pPhone
                }).then(()=> { alert("Profile Saved!"); document.getElementById('driverGreetingName').innerText = `Hello, ${pName.split(' ')[0]}`; });
            };

            function createDriverOrderCard(order, type) {
                const itemsString = order.items ? order.items.map(i => `${i.quantity}x ${i.name}`).join(', ') : 'No items';
                let actionBtn = '';

                if(type === 'request') {
                    actionBtn = `<button class="btn-main" style="margin:12px 0 0 0;" onclick="acceptOrder_driver('${order.id}')">Accept Order</button>`;
                } else if(type === 'active') {
                    actionBtn = `
                        <div style="margin-top:12px; display:flex; gap:8px;">
                            <button class="btn-main" style="margin:0; flex:1; background:#0984e3;" onclick="window.open('tel:${order.phone}')"><i class="fas fa-phone"></i> Call</button>
                            <button class="btn-main" style="margin:0; flex:2;" onclick="openVerifyModal_driver('${order.id}')">Verify & Deliver</button>
                        </div>
                    `;
                }

                let trackMap = type === 'active' ? `<div id="driver-track-map-${order.id}" style="height:180px; width:100%; border-radius:10px; margin-top:12px; display:none; border:2px solid var(--info);"></div>` : '';

                return `
                    <div class="order-card" style="margin:0 0 15px 0; box-shadow:0 4px 15px rgba(0,0,0,0.08);">
                        <div style="display:flex;justify-content:space-between;font-weight:600;margin-bottom:8px;">
                            <span>#${order.id.substring(1, 6)}</span>
                            <span style="color:${type==='history'?'var(--success)':'var(--primary-color)'}">${order.status}</span>
                        </div>
                        <p style="font-size:0.85em; margin:4px 0;"><strong>Customer:</strong> ${order.userName || 'N/A'}</p>
                        <p style="font-size:0.85em; margin:4px 0;"><strong>Phone:</strong> ${order.phone}</p>
                        <p style="font-size:0.85em; margin:4px 0; line-height:1.4;"><strong>Address:</strong> ${order.address}, ${order.village}, ${order.district}</p>
                        <div style="background:#f8f9fa; padding:10px; border-radius:10px; margin-top:10px;">
                            <p style="font-size:0.8em; color:#636e72; margin:0;">${itemsString}</p>
                            <p style="font-size:0.95em; font-weight:bold; margin:6px 0 0 0; color:var(--danger);">Total: ₹${order.total} <span style="font-size:0.8em; font-weight:normal; color:#2d3436;">(${order.method})</span></p>
                        </div>
                        ${trackMap}
                        ${actionBtn}
                    </div>
                `;
            }

            window.acceptOrder_driver = (id) => {
                db.ref('users/' + currentUser.uid).once('value', snap => {
                    const u = snap.val();
                    const dName = u.name || currentUser.displayName || "Assigned Driver";
                    const dPhone = u.driverPhone || "Unavailable";

                    db.ref('orders/' + id).update({ 
                        driverId: currentUser.uid, 
                        status: 'Out for Delivery',
                        driverName: dName,
                        driverPhone: dPhone
                    });

                    // Start GPS Tracking
                    if (navigator.geolocation) {
                        driverWatchIds[id] = navigator.geolocation.watchPosition(pos => {
                            db.ref('orders/' + id + '/driverLocation').set({
                                lat: pos.coords.latitude,
                                lng: pos.coords.longitude
                            });
                        }, err => console.error("GPS Error:", err), { enableHighAccuracy: true });
                    }
                });
            };

            window.openVerifyModal_driver = (id) => {
                orderIdToVerify_driver = id;
                document.getElementById('deliveryCodeInput_driver').value = '';
                document.getElementById('deliveryCodeModal_driver').style.display = 'flex';
                document.getElementById('deliveryCodeInput_driver').focus();
            };

            function fetchOrders_driver() {
                db.ref('orders').on('value', snapshot => {
                    const reqCont = document.getElementById('driverRequestsContainer');
                    const actCont = document.getElementById('driverActiveContainer');
                    const histCont = document.getElementById('driverHistoryContainer');
                    
                    reqCont.innerHTML = ''; actCont.innerHTML = ''; histCont.innerHTML = '';
                    
                    let reqCount = 0; let actCount = 0; let histCount = 0;
                    
                    snapshot.forEach(child => {
                        const order = { id: child.key, ...child.val() };
                        
                        // Requests: Placed or Preparing, NO driver assigned
                        if((order.status === 'Placed' || order.status === 'Preparing') && !order.driverId) {
                            reqCount++;
                            reqCont.innerHTML += createDriverOrderCard(order, 'request');
                        }
                        // Active: Out for Delivery, assigned to THIS driver
                        else if(order.status === 'Out for Delivery' && order.driverId === currentUser.uid) {
                            actCount++;
                            actCont.innerHTML += createDriverOrderCard(order, 'active');
                            
                            if(order.location) {
                                setTimeout(() => {
                                    initOrUpdateMap(`driver-track-map-${order.id}`, 
                                        order.location.lat, order.location.lng, 
                                        order.driverLocation?.lat, order.driverLocation?.lng
                                    );
                                }, 100);
                            }
                        }
                        // History: Delivered, assigned to THIS driver
                        else if(order.status === 'Delivered' && order.driverId === currentUser.uid) {
                            histCount++;
                            histCont.insertAdjacentHTML('afterbegin', createDriverOrderCard(order, 'history'));
                        }
                    });

                    if(reqCount===0) reqCont.innerHTML = '<p style="text-align:center; color:#777;">No new requests.</p>';
                    if(actCount===0) actCont.innerHTML = '<p style="text-align:center; color:#777;">No active deliveries.</p>';
                    if(histCount===0) histCont.innerHTML = '<p style="text-align:center; color:#777;">No delivery history.</p>';

                    document.getElementById('stat-requests_driver').textContent = reqCount;
                    document.getElementById('stat-active_driver').textContent = actCount;
                    document.getElementById('stat-completed_driver').textContent = histCount;
                });
            }

            function finalizeDriverDelivery(orderId, orderTotal, isCashCollected) {
                db.ref('orders/' + orderId).update({ status: 'Delivered' });
                
                if(driverWatchIds[orderId]) {
                    navigator.geolocation.clearWatch(driverWatchIds[orderId]);
                    delete driverWatchIds[orderId];
                }
                
                // Add commission
                db.ref('users/' + currentUser.uid + '/earnings').once('value', s => {
                    db.ref('users/' + currentUser.uid).update({ earnings: (s.val() || 0) + globalDriverCommission });
                });

                if(isCashCollected) {
                    db.ref('users/' + currentUser.uid + '/collectedCash').once('value', s => {
                        db.ref('users/' + currentUser.uid).update({ collectedCash: (s.val() || 0) + parseFloat(orderTotal) });
                    });
                }
            }

            document.getElementById('verifyCodeBtn_driver').onclick = () => {
                const userInput = document.getElementById('deliveryCodeInput_driver').value;
                if(!userInput || !orderIdToVerify_driver) {
                    alert("Please enter the delivery code.");
                    return;
                }
                db.ref('orders/' + orderIdToVerify_driver).once('value', snap => {
                    const orderObj = snap.val();
                    if(userInput == orderObj.deliveryCode) {
                        document.getElementById('deliveryCodeModal_driver').style.display = 'none';
                        document.getElementById('deliveryCodeInput_driver').value = '';

                        if (orderObj.method.toLowerCase().includes('cash') || orderObj.method === 'cod') {
                            // Check if they already paid online from tracking page beforehand
                            if(orderObj.paymentStatus === 'Paid') {
                                finalizeDriverDelivery(orderIdToVerify_driver, orderObj.total, false);
                                alert("Customer already paid online! Delivered successfully! Commission added.");
                                orderIdToVerify_driver = null;
                            } else {
                                window.currentDeliveryOrderId = orderIdToVerify_driver;
                                window.currentDeliveryOrderTotal = orderObj.total;
                                document.getElementById('paymentModalAmount').textContent = orderObj.total;
                                
                                // Auto generate URL for Razorpay QR Payment
                                const payUrl = window.location.origin + window.location.pathname + '?payOrder=' + orderIdToVerify_driver;
                                document.getElementById('paymentModalQR').src = `https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=${encodeURIComponent(payUrl)}`;
                                
                                document.getElementById('driverPaymentModal').style.display = 'flex';

                                // Listener for auto-detecting Razorpay payment success
                                if(window.driverPaymentListener) {
                                    db.ref('orders/' + window.currentDeliveryOrderId).off('value', window.driverPaymentListener);
                                }
                                window.driverPaymentListener = db.ref('orders/' + window.currentDeliveryOrderId).on('value', snap2 => {
                                    const updatedOrder = snap2.val();
                                    if(updatedOrder && updatedOrder.paymentStatus === 'Paid' && updatedOrder.status !== 'Delivered') {
                                        finalizeDriverDelivery(window.currentDeliveryOrderId, window.currentDeliveryOrderTotal, false);
                                        document.getElementById('driverPaymentModal').style.display = 'none';
                                        alert("Customer Payment Received Automatically via Razorpay! Order Delivered.");
                                        resetDriverVerification();
                                    }
                                });
                            }
                        } else {
                            finalizeDriverDelivery(orderIdToVerify_driver, orderObj.total, false);
                            alert("Delivered successfully! Commission added.");
                            orderIdToVerify_driver = null;
                        }
                    } else {
                        alert("Incorrect Code! Please try again.");
                        document.getElementById('deliveryCodeInput_driver').value = '';
                    }
                });
            };

            document.getElementById('driverCashSuccessBtn').onclick = () => {
                finalizeDriverDelivery(window.currentDeliveryOrderId, window.currentDeliveryOrderTotal, true);
                document.getElementById('driverPaymentModal').style.display = 'none';
                alert("Cash Collected! Delivered successfully! Commission added.");
                resetDriverVerification();
            };

            function resetDriverVerification() {
                if (window.driverPaymentListener && window.currentDeliveryOrderId) {
                    db.ref('orders/' + window.currentDeliveryOrderId).off('value', window.driverPaymentListener);
                    window.driverPaymentListener = null;
                }
                orderIdToVerify_driver = null;
                window.currentDeliveryOrderId = null;
                window.currentDeliveryOrderTotal = null;
            }

            document.querySelectorAll('#driverPage .close-modal').forEach(btn => {
                btn.onclick = () => {
                    const modalId = btn.dataset.modal;
                    document.getElementById(modalId).style.display = 'none';
                    if (modalId === 'deliveryCodeModal_driver' || modalId === 'driverPaymentModal') {
                        resetDriverVerification();
                        document.getElementById('deliveryCodeInput_driver').value = '';
                    }
                };
            });

            fetchOrders_driver();
        }
        
        // =========================================================
        // RAZORPAY QR PAYMENT AUTO-DETECTION (Standalone)
        // =========================================================
        document.addEventListener("DOMContentLoaded", () => {
            const urlParams = new URLSearchParams(window.location.search);
            const payOrderId = urlParams.get('payOrder');
            
            if (payOrderId) {
                setTimeout(() => {
                    db.ref('orders/' + payOrderId).once('value', snap => {
                        const order = snap.val();
                        if (order && order.paymentStatus !== 'Paid') {
                            const options = {
                                "key": "rzp_live_SUarhYm5IfBTar", 
                                "amount": Math.round(order.total * 100), 
                                "currency": "INR",
                                "name": "Sintha Keithel", 
                                "description": "Pay COD Order Online",
                                "image": "https://cdn-icons-png.flaticon.com/512/3075/3075977.png",
                                "handler": (response) => {
                                    db.ref('orders/' + payOrderId).update({
                                        paymentStatus: 'Paid',
                                        method: 'Paid Online',
                                        paymentId: response.razorpay_payment_id
                                    }).then(() => {
                                        alert("Payment successful! The driver has been notified automatically.");
                                        window.location.href = window.location.origin + window.location.pathname;
                                    });
                                },
                                "prefill": { "name": order.userName, "email": order.email || "guest@example.com", "contact": order.phone },
                                "theme": { "color": "#008743" }
                            };
                            try {
                                const rzp1 = new Razorpay(options);
                                rzp1.on('payment.failed', (response) => alert("Payment Failed: " + response.error.description));
                                rzp1.open();
                            } catch(e) { alert("Payment gateway failed to load."); }
                        } else if (order && order.paymentStatus === 'Paid') {
                            alert("This order is already paid.");
                            window.location.href = window.location.origin + window.location.pathname;
                        } else {
                            alert("Order not found.");
                            window.location.href = window.location.origin + window.location.pathname;
                        }
                    });
                }, 1500); // Give Firebase a moment to connect
            }
        });
    </script>
</body>
</html>
