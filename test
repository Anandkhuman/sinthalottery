        function createDishCardHTML(d) {
            const price = parseFloat(d.price) || 0;
            const stock = parseInt(d.stock) || 0;
            const outOfStock = stock <= 0;
            
            return `
                ${outOfStock ? `<div class="out-of-stock-overlay">Not Available</div>` : ''}
                <img src="${d.imageUrl}" alt="Dish" style="${outOfStock ? 'filter: grayscale(100%); opacity:0.6;' : ''}">
                <div class="card-content">
                    <h3 style="${outOfStock ? 'text-decoration:line-through; color:#999;' : ''}">${d.name}</h3>
                    <p style="${outOfStock ? 'color:#999;' : ''}">₹${price.toFixed(2)} <span style="font-size:0.7em; color:#666;">/${d.measurement||'pc'}</span></p>
                </div>
            `;
        }

        function renderPopularDishes(dishesList) {
            const c = document.getElementById('popularDishesContainer');
            c.innerHTML = '';
            let popular =[...dishesList].sort(() => 0.5 - Math.random()).slice(0, 5);
            if(popular.length === 0) { 
                c.innerHTML = '<p style="padding:10px; color:#666; width:100%; text-align:center;">No popular dishes right now.</p>'; 
                return; 
            }
            popular.forEach(d => {
                const stock = parseInt(d.stock) || 0;
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = createDishCardHTML(d);
                
                const addBtn = document.createElement('button');
                if(stock <= 0) {
                    addBtn.className = 'add-btn'; addBtn.style.background = '#ccc'; addBtn.disabled = true; addBtn.innerHTML = '<i class="fas fa-ban"></i>';
                } else {
                    addBtn.className = 'add-btn'; addBtn.innerHTML = '<i class="fas fa-plus"></i>';
                    addBtn.onclick = () => addToCart(d.key, d.name, d.price, d.imageUrl, stock);
                }
                card.appendChild(addBtn);
                c.appendChild(card);
            });
        }

