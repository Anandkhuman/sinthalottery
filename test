            document.getElementById('csvFileInput_admin').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if(!file) return;
                const categorySelect = document.getElementById('csvCategorySelect_admin');
                const catId = categorySelect.value;
                const catName = categorySelect.options[categorySelect.selectedIndex]?.text || '';
                if(!catId) { alert('Please select a Category from the dropdown first!'); return; }

                const reader = new FileReader();
                reader.onload = function(event) {
                    const text = event.target.result;
                    const rows = text.split('\n');
                    let count = 0;
                    rows.forEach((row, index) => {
                        if(index === 0) return; 
                        const cols = row.split(',');
                        if(cols.length >= 5) {
                            const name = cols[0].trim();
                            const measurement = cols[1].trim();
                            const price = parseFloat(cols[2].trim());
                            const stock = parseInt(cols[3].trim());
                            const imageUrl = cols[4].trim();
                            
                            if(name && price) {
                                db.ref('dishes').push({
                                    name, measurement, price, stock, imageUrl,
                                    categoryId: catId, categoryName: catName
                                });
                                count++;
                            }
                        }
                    });
                    alert(count + ' items uploaded successfully!');
                };
                reader.readAsText(file);
                e.target.value = '';
            });

