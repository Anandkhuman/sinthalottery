        document.getElementById('geoBtn').addEventListener('click', () => {
            const btn = document.getElementById('geoBtn');
            document.getElementById('map-container').style.display = 'block';
            if(!map) {
                map = L.map('map').setView([24.8170, 93.9368], 13); 
                L.tileLayer('https://mt1.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', { maxZoom: 20, attribution: '© Google' }).addTo(map);
                map.on('click', (e) => handleLocationUpdate(e.latlng.lat, e.latlng.lng));
            }
            map.invalidateSize();
            if (navigator.geolocation) {
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Locating...';
                navigator.geolocation.getCurrentPosition(
                    (p) => {
                        handleLocationUpdate(p.coords.latitude, p.coords.longitude);
                        map.setView([p.coords.latitude, p.coords.longitude], 16);
                        btn.innerHTML = '<i class="fas fa-check"></i> Location Set';
                    },
                    (e) => { alert("Geolocation permission denied. Please click on the map or enter your address manually."); btn.innerHTML = '<i class="fas fa-location-arrow"></i> Use My Current Location'; }
                );
            }
