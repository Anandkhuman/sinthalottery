        auth.onAuthStateChanged(u => {
            if(u) {
                db.ref('users/' + u.uid).once('value', snap => {
                    let userData = snap.val();
                    if (!userData) {
                        userData = {
                            email: u.email,
                            name: u.displayName || pendingRegName || 'Guest',
                            role: '',
                            banned: false,
                            createdAt: Date.now()
                        };
                        db.ref('users/' + u.uid).set(userData).then(() => {
                            checkRoleAndProceed(u, userData);
                        });
                    } else {
                        if ((!userData.name || userData.name === 'Guest') && (u.displayName || pendingRegName)) {
                            userData.name = u.displayName || pendingRegName;
                            db.ref('users/' + u.uid).update({ name: userData.name });
                        }
                        checkRoleAndProceed(u, userData);
                    }
                });
            } else {
                currentUser = null;
                currentUserData = null;
                showPage('loginPage');
                if (ordersRef) ordersRef.off();
                if (notificationsListener) notificationsListener.off();
            }
        });

        // Safe Function to fetch DB state and show proper role selection page
        function checkRoleAndProceed(u, userData) {
            if(userData.banned) {
                auth.signOut();
                alert("Your account has been banned by the Admin.");
                return;
            }
            currentUser = u;
            currentUserData = userData;

            if(!userData.role || userData.role === '') {
                // Ensure we get the fresh setting straight from Firebase to avoid skipping
                db.ref('settings').once('value').then(setSnap => {
                    let canSelect = false;
                    if(setSnap.exists() && setSnap.val().enableRoleSelection !== undefined) {
                        canSelect = setSnap.val().enableRoleSelection;
                    }
                    
                    if(canSelect === true || canSelect === "true") {
                        showPage('roleSelectPage');
                    } else {
                        db.ref('users/' + u.uid).update({ role: 'customer' }).then(() => {
                            userData.role = 'customer';
                            finalizeLogin('customer', u, userData);
                        });
                    }
                }).catch(err => {
                    console.error("Error fetching settings", err);
                    // Fallback to customer if db fails
                    db.ref('users/' + u.uid).update({ role: 'customer' }).then(() => {
                        userData.role = 'customer';
                        finalizeLogin('customer', u, userData);
                    });
                });
            } else {
                finalizeLogin(userData.role, u, userData);
            }
        }

