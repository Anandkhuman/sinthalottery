                "prefill": { "name": name, "email": currentUser ? currentUser.email : "guest@example.com", "contact": phone },
                "theme": { "color": "#008743" }
            };
            try {
                const rzp1 = new Razorpay(options);
                rzp1.on('payment.failed', (response) => alert("Payment Failed: " + response.error.description));
                rzp1.open();
            } catch (err) { alert("Payment interface failed to load."); }
        };

        function createOrderCardHTML(orderKey, orderData) {
            let o = orderData;
            let st = o.status || 'Placed';
            let s1 = '', s2 = '', s3 = '', s4 = '';
            if (st === 'Placed') s1 = 'active';
            else if (st === 'Preparing') { s1 = 'passed'; s2 = 'active'; }
            else if (st === 'Out for Delivery') { s1 = 'passed'; s2 = 'passed'; s3 = 'active'; }
            else if (st === 'Delivered') { s1 = 'passed'; s2 = 'passed'; s3 = 'passed'; s4 = 'active'; }

            let itemsDisplay = (o.items && Array.isArray(o.items)) 
                                ? o.items.map(i => `${i.quantity || 1}x ${i.name || 'Item'}`).join(', ') 
                                : "Items not found";

            const showPayBtn = (o.method === 'Cash on Delivery' || o.method === 'cod') && o.paymentStatus !== 'Paid' && st !== 'Delivered';

            const orderStr = encodeURIComponent(JSON.stringify({id: orderKey, ...orderData}));
            const downloadBtn = st === 'Delivered' ? `
                <button class="btn-main" style="margin-top:15px; background: #fff; color: var(--primary-color); border: 2px solid var(--primary-color); padding: 10px; font-size: 0.9em; box-shadow: none;" onclick="downloadInvoice('${orderStr}')">
                    <i class="fas fa-file-invoice"></i> Download Invoice
                </button>
            ` : '';

            return `
                <div style="display:flex;justify-content:space-between;font-weight:600;">
                    <span style="color:var(--text-color);">#${orderKey.substring(1, 6)}</span>
                    <span style="color:var(--primary-color)">${st}</span>
                </div>
                <p style="font-size:0.85em; color:#636e72;">${itemsDisplay}</p>
                <p style="text-align:right; font-weight:700; font-size:1.05em; margin-bottom: 15px;">Total: ₹${o.total || '0'}</p>

                ${st !== 'Delivered' && o.deliveryCode ? `
                    <div style="background:#e6f7ef; padding:10px; border-radius:10px; text-align:center; margin:12px 0;">
                        <p style="margin:0; font-size:0.75em; color:#008743; font-weight:600;">DELIVERY CODE</p>
                        <h2 style="margin:0; letter-spacing:4px; color:#2d3436;">${o.deliveryCode}</h2>
                    </div>
                ` : ''}

                ${o.status === 'Out for Delivery' && o.driverName ? `
                    <div style="background:#fff5e6; padding:10px; border-radius:10px; margin-top:8px; border:1px dashed var(--primary-dark);">
                        <p style="margin:0; font-size:0.8em; color:#333;"><strong>Driver:</strong> ${o.driverName}</p>
                        <p style="margin:0; font-size:0.8em; color:#333;"><strong>Contact:</strong> <a href="tel:${o.driverPhone}" style="color:var(--primary-color); text-decoration:none;">${o.driverPhone}</a></p>
                    </div>
                ` : ''}

                ${showPayBtn ? `
                    <button class="btn-main" style="margin-top:8px; margin-bottom:12px; background: linear-gradient(135deg, #0984e3 0%, #2d3436 100%); padding: 10px; font-size: 0.9em;" onclick="payCodOnline('${orderKey}', ${o.total}, '${o.userName}', '${o.phone}')">
                        <i class="fas fa-qrcode"></i> Pay Online via Razorpay
                    </button>
                ` : ''}

                <div class="track-bar">
                    <div class="track-step ${s1}"><div class="dot"></div><p>Placed</p></div>
                    <div class="track-step ${s2}"><div class="dot"></div><p>Prep</p></div>
                    <div class="track-step ${s3}"><div class="dot"></div><p>On Way</p></div>
                    <div class="track-step ${s4}"><div class="dot"></div><p>Done</p></div>
                </div>
                ${downloadBtn}
                <div id="track-map-${orderKey}" style="height:180px; width:100%; margin-top:12px; border-radius:10px; display:none; border:2px solid var(--primary-color);"></div>
            `;
        }
        
        function loadOrders() {
            const container = document.getElementById('ordersListContainer');
            const placeholder = document.getElementById('orders-placeholder');
            
            if (ordersRef) { ordersRef.off(); }
            container.innerHTML = ''; 
            container.appendChild(placeholder);
            placeholder.style.display = 'block';
            placeholder.textContent = "Loading your orders...";

            if (!currentUser) return;

            ordersRef = db.ref('orders').orderByChild('userId').equalTo(currentUser.uid);
            
            ordersRef.once('value', snapshot => {
                if (!snapshot.exists()) {
                    placeholder.textContent = "You haven't placed any orders yet.";
                }
            });

            ordersRef.on('child_added', (snapshot) => {
                placeholder.style.display = 'none'; 
                const orderKey = snapshot.key;
                const orderData = snapshot.val();
                
                const card = document.createElement('div');
                card.className = 'order-card';
                card.id = `order-${orderKey}`;
                card.innerHTML = createOrderCardHTML(orderKey, orderData);
                container.prepend(card);

                if (orderData.status === 'Out for Delivery' && orderData.location) {
                    setTimeout(() => {
                        initOrUpdateMap(`track-map-${orderKey}`, 
                            orderData.location.lat, orderData.location.lng, 
                            orderData.driverLocation?.lat, orderData.driverLocation?.lng);
                    }, 100);
                }
            });

            ordersRef.on('child_changed', (snapshot) => {
                const orderKey = snapshot.key;
                const orderData = snapshot.val();
                
                const card = document.getElementById(`order-${orderKey}`);
                if (card) {
                    card.innerHTML = createOrderCardHTML(orderKey, orderData);
                    const mapEl = document.getElementById(`track-map-${orderKey}`);
                    
                    if (orderData.status === 'Out for Delivery' && orderData.location) {
                        setTimeout(() => {
                            initOrUpdateMap(`track-map-${orderKey}`, 
                                orderData.location.lat, orderData.location.lng, 
                                orderData.driverLocation?.lat, orderData.driverLocation?.lng);
                        }, 100);
                    } else if (mapEl) {
                        mapEl.style.display = 'none';
                    }
                }
            });
        }


