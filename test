        // Tracking Map Variables 
        const allMaps = {};
        const allMarkers = {};

        function initOrUpdateMap(mapContainerId, destLat, destLng, driverLat, driverLng) {
            const mapEl = document.getElementById(mapContainerId);
            if (!mapEl) return;
            
            mapEl.style.display = 'block';
            
            let mapObj = allMaps[mapContainerId];
            if (!mapObj) {
                mapObj = L.map(mapContainerId);
                L.tileLayer('https://mt1.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', { maxZoom: 20, attribution: '© Google' }).addTo(mapObj);
                allMaps[mapContainerId] = mapObj;
                allMarkers[mapContainerId] = { dest: null, driver: null };
            }

            setTimeout(() => mapObj.invalidateSize(), 300);

            const markers = allMarkers[mapContainerId];

            if (destLat && destLng) {
                const destLatLng = [destLat, destLng];
                if (!markers.dest) {
                    markers.dest = L.marker(destLatLng).addTo(mapObj).bindPopup("Delivery Address");
                } else {
                    markers.dest.setLatLng(destLatLng);
                }
            }

            if (driverLat && driverLng) {
                const driverLatLng =[driverLat, driverLng];
                if (!markers.driver) {
                    const icon = L.divIcon({html: '<i class="fas fa-motorcycle" style="color:#d63031; font-size:24px; text-shadow:1px 1px 2px #000;"></i>', className: 'driver-icon', iconSize:[24,24]});
                    markers.driver = L.marker(driverLatLng, {icon: icon}).addTo(mapObj).bindPopup("Driver");
                } else {
                    markers.driver.setLatLng(driverLatLng);
                }
            }

            if (markers.dest && markers.driver) {
                mapObj.fitBounds(L.latLngBounds(markers.dest.getLatLng(), markers.driver.getLatLng()), {padding:[30,30]});
            } else if (markers.dest) {
                mapObj.setView(markers.dest.getLatLng(), 15);
            } else if (markers.driver) {
                mapObj.setView(markers.driver.getLatLng(), 15);
            }
        }

        // =========================================================
        // INVOICE GENERATION LOGIC (Optimized Alignment & Margins)
        // =========================================================
        window.downloadInvoice = (orderStr) => {
            const order = JSON.parse(decodeURIComponent(orderStr));
            const invoiceEl = document.createElement('div');
            
            // Fixed width to 700px to perfectly fit A4 sizing and prevent right side cutoff
            invoiceEl.style.padding = '30px'; 
            invoiceEl.style.fontFamily = "'Poppins', sans-serif";
            invoiceEl.style.color = '#2d3436';
            invoiceEl.style.background = '#fff';
            invoiceEl.style.width = '700px'; 
            invoiceEl.style.boxSizing = 'border-box';

            let itemsHtml = '';
            let subtotal = 0;
            if(order.items && Array.isArray(order.items)) {
                order.items.forEach(item => {
                    let itemTotal = item.price * item.quantity;
                    subtotal += itemTotal;
                    itemsHtml += `
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px 10px; text-align: left;">${item.name}</td>
                            <td style="padding: 12px 10px; text-align: center;">₹${item.price.toFixed(2)}</td>
                            <td style="padding: 12px 10px; text-align: center;">${item.quantity}</td>
                            <td style="padding: 12px 10px; text-align: right;">₹${itemTotal.toFixed(2)}</td>
                        </tr>
                    `;
                });
            }

            let deliveryFee = parseFloat(order.total) - subtotal;
            if(deliveryFee < 0) deliveryFee = 0; 

            invoiceEl.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #008743; padding-bottom: 20px; margin-bottom: 30px;">
                    <div style="flex: 1;">
                        <h1 style="color: #008743; margin: 0; font-size: 2.2em; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-mug-hot"></i> Sintha Keithel
                        </h1>
                        <p style="margin: 5px 0 0 0; color: #636e72; font-size: 0.9em;">www.sinthakeithel.com</p>
                        <p style="margin: 2px 0 0 0; color: #636e72; font-size: 0.9em;">support@sinthakeithel.com</p>
                    </div>
                    <div style="text-align: right; flex: 1;">
                        <h2 style="margin: 0; color: #2d3436; font-size: 1.8em; text-transform: uppercase; letter-spacing: 2px;">Invoice</h2>
                        <p style="margin: 5px 0 0 0; font-weight: 600; font-size: 0.95em;">Order ID: #${order.id.substring(1, 8).toUpperCase()}</p>
                        <p style="margin: 2px 0 0 0; color: #636e72; font-size: 0.9em;">Date: ${new Date(order.timestamp).toLocaleString()}</p>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
                    <div style="flex: 1; padding-right: 15px;">
                        <h3 style="color: #008743; margin-top: 0; margin-bottom: 8px; font-size: 1.05em; text-transform: uppercase;">Billed To:</h3>
                        <p style="margin: 0; font-weight: 600; font-size: 1.05em;">${order.userName}</p>
                        <p style="margin: 4px 0 0 0; color: #636e72; font-size: 0.9em;">${order.phone}</p>
                        <p style="margin: 2px 0 0 0; color: #636e72; font-size: 0.9em; line-height: 1.4;">${order.address}, ${order.village},<br>${order.district}, ${order.state} - ${order.pin}</p>
                    </div>
                    <div style="text-align: right; flex: 1; padding-left: 15px;">
                        <h3 style="color: #008743; margin-top: 0; margin-bottom: 8px; font-size: 1.05em; text-transform: uppercase;">Payment Details:</h3>
                        <p style="margin: 0; font-weight: 600; font-size: 0.95em;">Method: ${order.method}</p>
                        <p style="margin: 4px 0 0 0; color: ${order.paymentStatus === 'Paid' ? '#00b894' : '#d63031'}; font-weight: 600; font-size: 0.95em;">Status: ${order.paymentStatus}</p>
                        ${order.paymentId ? `<p style="margin: 2px 0 0 0; color: #636e72; font-size: 0.85em;">Txn: ${order.paymentId}</p>` : ''}
                    </div>
                </div>

                <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px; table-layout: fixed;">
                    <thead>
                        <tr style="background-color: #f4f6f8; border-bottom: 2px solid #dfe6e9;">
                            <th style="padding: 10px; text-align: left; color: #2d3436; width: 40%; font-size: 0.9em;">Description</th>
                            <th style="padding: 10px; text-align: center; color: #2d3436; width: 20%; font-size: 0.9em;">Price</th>
                            <th style="padding: 10px; text-align: center; color: #2d3436; width: 15%; font-size: 0.9em;">Qty</th>
                            <th style="padding: 10px; text-align: right; color: #2d3436; width: 25%; font-size: 0.9em;">Total</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.95em;">
                        ${itemsHtml}
                    </tbody>
                </table>

                <div style="display: flex; justify-content: flex-end;">
                    <div style="width: 280px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; color: #636e72; font-size: 0.95em;">
                            <span>Subtotal:</span>
                            <span>₹${subtotal.toFixed(2)}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px; color: #636e72; font-size: 0.95em;">
                            <span>Delivery Fee:</span>
                            <span>₹${deliveryFee.toFixed(2)}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-top: 2px solid #dfe6e9; padding-top: 12px; font-weight: 700; font-size: 1.2em; color: #008743;">
                            <span>Total Amount:</span>
                            <span>₹${parseFloat(order.total).toFixed(2)}</span>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 50px; text-align: center; border-top: 1px solid #eee; padding-top: 15px;">
                    <h3 style="color: #008743; margin: 0 0 4px 0; font-size: 1.1em;">Thank you for your order!</h3>
                    <p style="color: #636e72; margin: 0; font-size: 0.85em;">If you have any questions about this invoice, please contact our support.</p>
                </div>
            `;

            const container = document.getElementById('invoice-container');
            container.innerHTML = '';
            container.appendChild(invoiceEl);

            const opt = {
                margin:       10, // Margin in mm (ensures safety zones)
                filename:     `Invoice_${order.id.substring(1,8)}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true, windowWidth: 720 },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(invoiceEl).save().then(() => {
                container.innerHTML = '';
            });
        };

        // =========================================================
        // CUSTOMER UI NAVIGATION & LOGIC
        // =========================================================
        const showPage = (id) => {
            if (activePageId === 'ordersPage' && id !== 'ordersPage') {
                if (ordersRef) ordersRef.off();
            }
        
            activePageId = id;
            document.querySelectorAll('.page').forEach(p => p.classList.toggle('active', p.id === id));
            
            // Handle bottom nav active states for customer
            if(id === 'appContainer' || id === 'notificationsPage' || id === 'menuPage' || id === 'ordersPage' || id === 'cartPage' || id === 'checkoutPage') {
                document.querySelectorAll('#customerBottomNav .nav-item').forEach(nav => {
                    let navPage = nav.dataset.page;
                    // Orders map to menu nav visual
                    if(id === 'ordersPage' && navPage === 'menuPage') { nav.classList.add('active'); }
                    else if((id === 'cartPage' || id === 'checkoutPage') && navPage === 'appContainer') { nav.classList.add('active'); }
                    else { nav.classList.toggle('active', navPage === id); }
                });
            }
            
            const custNav = document.getElementById('customerBottomNav');
            const cartFab = document.getElementById('cart-fab-container');
            // Show bottom nav strictly for these screens (fixes hidden navigation)
            if (id === 'appContainer' || id === 'ordersPage' || id === 'notificationsPage' || id === 'menuPage' || id === 'cartPage' || id === 'checkoutPage') {
                custNav.style.display = 'flex';
                // Only hide floating cart FAB on cart and checkout page, but keep nav
                cartFab.style.display = (id === 'cartPage' || id === 'checkoutPage') ? 'none' : 'block';
            } else {
                custNav.style.display = 'none';
                cartFab.style.display = 'none';
            }

            if(id === 'loginPage' || id === 'registerPage' || id === 'forgotPasswordPage' || id === 'roleSelectPage') {
                document.body.classList.add('auth-screen');
            } else {
                document.body.classList.remove('auth-screen');
            }

            if(id === 'checkoutPage') {
                setTimeout(() => { if(map) map.invalidateSize(); }, 300);
                checkOrderValidity();
            }
            if(id === 'ordersPage') loadOrders();
            if(id === 'notificationsPage') {
                loadNotifications();
                markNotificationsAsRead();
            }
        };

        document.querySelectorAll('[data-target]:not(.close-modal), [data-page]').forEach(b => 
            b.addEventListener('click', (e) => {
                if(e.currentTarget.dataset.adminTarget || e.currentTarget.dataset.driverTarget) return; 
                const target = e.currentTarget.dataset.target || e.currentTarget.dataset.page;
                if(target) showPage(target);
            })
        );
        document.getElementById('gotoRegister').onclick = () => showPage('registerPage');
        document.getElementById('gotoLogin').onclick = () => showPage('loginPage');
        
        document.getElementById('gotoForgot').onclick = () => showPage('forgotPasswordPage');
        document.getElementById('backToLoginFromReset').onclick = () => showPage('loginPage');
        document.getElementById('sendResetBtn').onclick = () => {
            const email = document.getElementById('resetEmail').value;
            if(!email) {
                document.getElementById('reset-error').textContent = "Please enter an email address.";
                document.getElementById('reset-error').style.display = 'block';
                return;
            }
            auth.sendPasswordResetEmail(email)
                .then(() => {
                    document.getElementById('reset-success').textContent = "Reset link sent to your email.";
                    document.getElementById('reset-success').style.display = 'block';
                    document.getElementById('reset-error').style.display = 'none';
                }).catch(e => {
                    document.getElementById('reset-error').textContent = e.message;
                    document.getElementById('reset-error').style.display = 'block';
                    document.getElementById('reset-success').style.display = 'none';
                });
        };

        document.getElementById('menuLogoutBtn').onclick = () => { auth.signOut(); cart=[]; updateCartUI(); };
        
